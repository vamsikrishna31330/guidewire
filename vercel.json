{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "client/dist",
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    },
    "api/cron/disruptions.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/cron/disruptions",
      "destination": "/api/cron/disruptions.js"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
